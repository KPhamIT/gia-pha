// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RelationshipType {
  FATHER
  MOTHER
  SPOUSE
  CHILD
}

enum EventType {
  INFO
  CONTRIBUTION
}

enum DonationKind {
  MONEY
  IN_KIND
}

enum UserRole {
  SYSTEM
  ADMIN
  STANDARD
}

enum SubscriptionTier {
  FAMILY
  SMALL
  MEDIUM
  LARGE
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
}

enum BillingOrderStatus {
  PENDING_PAYMENT
  AWAITING_REVIEW
  CONFIRMED
  REJECTED
  CANCELLED
  EXPIRED
}

model User {
  id           Int      @id @default(autoincrement())
  email        String?  @unique
  username     String?  @unique
  passwordHash String?
  role         UserRole @default(STANDARD)
  provider     String
  providerId   String   @unique
  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  isActive Boolean @default(true)

  /// Tài khoản demo công khai (chỉ xem; bị chặn mọi thao tác ghi).
  isDemo Boolean @default(false)

  onesignalSubscriptionId String?

  notificationDeathAnniversaryEnabled Boolean @default(false)
  notificationEventEnabled            Boolean @default(false)
  notificationPostEnabled             Boolean @default(false)

  pushSubscriptions UserPushSubscription[]

  person   Person?
  settings UserSettings?
  exportPresets ExportPreset[]
  uploadedExportSystemAssets ExportSystemAsset[]
  notificationLogs NotificationLog[]
  personEditLogs    PersonEditLog[]
  lastEditedPersons Person[]        @relation("PersonLastEditor")
  reviewedBillingOrders BillingOrder[] @relation("BillingOrderReviewer")
  activatedSubscriptions OrganizationSubscription[] @relation("SubscriptionActivator")

  createdAt DateTime @default(now())

  @@index([organizationId, role])
  @@index([notificationDeathAnniversaryEnabled, isActive])
}

/// One row per browser/device — user có thể nhận push trên nhiều thiết bị.
model UserPushSubscription {
  id                      Int      @id @default(autoincrement())
  userId                  Int
  onesignalSubscriptionId String   @unique
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([userId])
}

model UserSettings {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  data      Json     @default("{}")
  user      User     @relation(fields: [userId], references: [id])
  updatedAt DateTime @updatedAt
}

model ExportPreset {
  id        Int      @id @default(autoincrement())
  userId    Int
  key       String
  label     String
  sortOrder Int      @default(0)
  data      Json
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
  @@index([userId, sortOrder])
}

enum ExportSystemAssetCategory {
  BACKGROUND
  SCROLL
  COUPLET
  OTHER
}

enum ExportSystemAssetAccess {
  FREE
  PAID
}

/// Ảnh trang trí phả đồ do SYSTEM upload — metadata trong DB, file trên storage.
model ExportSystemAsset {
  id               Int                       @id @default(autoincrement())
  name             String
  category         ExportSystemAssetCategory @default(OTHER)
  access           ExportSystemAssetAccess   @default(FREE)
  provider         String
  storageKey       String                    @unique
  url              String
  mimeType         String?
  width            Int?
  height           Int?
  bytes            Int?
  sortOrder        Int                       @default(0)
  isActive         Boolean                   @default(true)
  uploadedByUserId Int?
  uploadedBy       User?                     @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  @@index([isActive, category, sortOrder])
}

model Organization {
  id   Int    @id @default(autoincrement())
  name String

  /// Năm lập gia phả (hiển thị trên bìa sổ).
  establishedYear String?
  /// Địa chỉ dòng họ (hiển thị trên bìa sổ).
  clanAddress     String?

  /// Per-org overrides for STANDARD user feature flags (merged over system defaults).
  standardFeatures Json?

  persons Person[]
  users   User[]

  events Event[]

  notificationLogs NotificationLog[]

  ceremonyTemplates CeremonyTemplate[]

  billingOrders BillingOrder[]
  subscriptions OrganizationSubscription[]

  createdAt DateTime @default(now())
}

model BillingOrder {
  id             Int                @id @default(autoincrement())
  organizationId Int
  transferCode   String             @unique
  tier           SubscriptionTier
  personCountAtOrder Int
  amountVnd      Int
  status         BillingOrderStatus @default(PENDING_PAYMENT)
  contactName    String?
  contactPhone   String?
  contactEmail   String?
  note           String?
  paidAt         DateTime?
  reviewedAt     DateTime?
  reviewedByUserId Int?
  reviewNote     String?
  expiresAt      DateTime
  createdAt      DateTime           @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reviewedBy   User?        @relation("BillingOrderReviewer", fields: [reviewedByUserId], references: [id])
  subscription OrganizationSubscription?

  @@index([organizationId, status])
  @@index([status, createdAt])
}

model OrganizationSubscription {
  id                    Int                @id @default(autoincrement())
  organizationId        Int
  tier                  SubscriptionTier
  personCountAtPurchase Int
  status                SubscriptionStatus
  startsAt              DateTime
  expiresAt             DateTime
  amountVnd             Int
  billingOrderId        Int?               @unique
  paymentRef            String?
  activatedByUserId     Int?
  createdAt             DateTime           @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  billingOrder BillingOrder? @relation(fields: [billingOrderId], references: [id])
  activatedBy  User?         @relation("SubscriptionActivator", fields: [activatedByUserId], references: [id])

  @@index([organizationId, status, expiresAt])
}

model CeremonyTemplate {
  id Int @id @default(autoincrement())

  organizationId Int

  name String

  /// HTML với biến {{person.full_name}}, {{organization.name}}, ...
  content String @db.Text

  isDefault Boolean @default(false)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, isDefault])
}

model AppConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model Event {
  id Int @id @default(autoincrement())

  organizationId Int

  title String

  description String? @db.Text

  type EventType @default(INFO)

  eventDate DateTime?

  // Fixed contribution amount per person (VND) for CONTRIBUTION events.
  amountPerPerson Int @default(0)

  // When true, only living male members are expected to contribute.
  maleOnly Boolean @default(false)

  organization Organization @relation(fields: [organizationId], references: [id])

  contributions EventContribution[]

  donations EventDonation[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model EventDonation {
  id Int @id @default(autoincrement())

  eventId Int

  // Optional link to a family-tree member; null for outside donors.
  personId Int?

  donorName String

  kind DonationKind @default(MONEY)

  amount Int @default(0)

  /** Description when kind is IN_KIND (e.g. "5 kg gạo"). */
  itemDescription String? @db.Text

  note String? @db.Text

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  person Person? @relation(fields: [personId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model EventContribution {
  id Int @id @default(autoincrement())

  eventId Int

  personId Int

  paid Boolean @default(true)

  // VND collected from this person (may be less than Event.amountPerPerson).
  amountPaid Int @default(0)

  paidAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  @@unique([eventId, personId])
}

model Person {
  id Int @id @default(autoincrement())

  organizationId Int

  userId Int? @unique

  fullName String

  gender String?

  birthDate DateTime?

  deathDate DateTime?

  /// Ngày mất theo âm lịch (1–30).
  deathLunarDay Int?

  /// Tháng mất theo âm lịch (1–12).
  deathLunarMonth Int?

  // Explicit life status — set when the death date is unknown but the person
  // is known to have passed away.
  deceased Boolean @default(false)

  avatar String?

  generation Int?

  branch Int? @default(1)

  birthPlace String?

  currentLocation String?

  education String?

  occupation String?

  religion String?

  ethnicity String?

  achievements String? @db.Text

  organization Organization @relation(fields: [organizationId], references: [id])

  user User? @relation(fields: [userId], references: [id])

  fromRelations Relationship[] @relation("fromPerson")

  toRelations Relationship[] @relation("toPerson")

  biography Biography?

  graveInfo GraveInfo?

  contributions EventContribution[]

  donations EventDonation[]

  notificationLogs NotificationLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lastEditedByUserId Int?
  lastEditedBy       User? @relation("PersonLastEditor", fields: [lastEditedByUserId], references: [id], onDelete: SetNull)

  editLogs PersonEditLog[]

  @@index([organizationId, deceased, deathLunarMonth, deathLunarDay])
  @@index([lastEditedByUserId])
}

model PersonEditLog {
  id       Int      @id @default(autoincrement())
  personId Int
  userId   Int
  editedAt DateTime @default(now())

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([personId, editedAt(sort: Desc)])
}

enum NotificationStatus {
  SENT
  FAILED
  SKIPPED
}

enum BlogCategory {
  BASICS
  HOWTO
  CULTURE
  FAMILY_TREE
  ONLINE
  SEO
}

model BlogPost {
  id              Int          @id @default(autoincrement())
  slug            String       @unique
  title           String
  excerpt         String       @db.Text
  content         String       @db.Text
  metaDescription String       @db.VarChar(320)
  category        BlogCategory
  tags            String[]
  published       Boolean      @default(true)
  publishedAt     DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([published, publishedAt(sort: Desc)])
  @@index([category, published])
}

model NotificationLog {
  id Int @id @default(autoincrement())

  organizationId Int
  userId         Int
  personId       Int?

  title   String
  message String @db.Text

  status NotificationStatus @default(SENT)

  sentAt    DateTime?
  createdAt DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  person       Person?      @relation(fields: [personId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([organizationId, createdAt])
  @@index([personId, userId, createdAt])
}

model Biography {
  id        Int      @id @default(autoincrement())
  personId  Int      @unique
  content   String   @db.Text
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt
}

model GraveInfo {
  id        Int      @id @default(autoincrement())
  personId  Int      @unique
  cemetery  String?
  address   String?
  notes     String?  @db.Text
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt
}

model Relationship {
  id Int @id @default(autoincrement())

  fromId Int

  toId Int

  type RelationshipType

  from Person @relation("fromPerson", fields: [fromId], references: [id])

  to Person @relation("toPerson", fields: [toId], references: [id])

  createdAt DateTime @default(now())
}
