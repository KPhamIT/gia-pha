// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RelationshipType {
  FATHER
  MOTHER
  SPOUSE
  CHILD
}

enum EventType {
  INFO
  CONTRIBUTION
}

enum DonationKind {
  MONEY
  IN_KIND
}

model User {
  id         Int     @id @default(autoincrement())
  email      String? @unique
  provider   String
  providerId String  @unique

  person   Person?
  settings UserSettings?
  exportPresets ExportPreset[]

  createdAt DateTime @default(now())
}

model UserSettings {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  data      Json     @default("{}")
  user      User     @relation(fields: [userId], references: [id])
  updatedAt DateTime @updatedAt
}

model ExportPreset {
  id        Int      @id @default(autoincrement())
  userId    Int
  key       String
  label     String
  sortOrder Int      @default(0)
  data      Json
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
  @@index([userId, sortOrder])
}

model Organization {
  id   Int    @id @default(autoincrement())
  name String

  persons Person[]

  events Event[]

  createdAt DateTime @default(now())
}

model Event {
  id Int @id @default(autoincrement())

  organizationId Int

  title String

  description String? @db.Text

  type EventType @default(INFO)

  eventDate DateTime?

  // Fixed contribution amount per person (VND) for CONTRIBUTION events.
  amountPerPerson Int @default(0)

  // When true, only living male members are expected to contribute.
  maleOnly Boolean @default(false)

  organization Organization @relation(fields: [organizationId], references: [id])

  contributions EventContribution[]

  donations EventDonation[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model EventDonation {
  id Int @id @default(autoincrement())

  eventId Int

  // Optional link to a family-tree member; null for outside donors.
  personId Int?

  donorName String

  kind DonationKind @default(MONEY)

  amount Int @default(0)

  /** Description when kind is IN_KIND (e.g. "5 kg gạo"). */
  itemDescription String? @db.Text

  note String? @db.Text

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  person Person? @relation(fields: [personId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model EventContribution {
  id Int @id @default(autoincrement())

  eventId Int

  personId Int

  paid Boolean @default(true)

  // VND collected from this person (may be less than Event.amountPerPerson).
  amountPaid Int @default(0)

  paidAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  @@unique([eventId, personId])
}

model Person {
  id Int @id @default(autoincrement())

  organizationId Int

  userId Int? @unique

  fullName String

  gender String?

  birthDate DateTime?

  deathDate DateTime?

  // Explicit life status — set when the death date is unknown but the person
  // is known to have passed away.
  deceased Boolean @default(false)

  avatar String?

  generation Int?

  branch Int? @default(1)

  birthPlace String?

  currentLocation String?

  education String?

  occupation String?

  religion String?

  ethnicity String?

  achievements String? @db.Text

  organization Organization @relation(fields: [organizationId], references: [id])

  user User? @relation(fields: [userId], references: [id])

  fromRelations Relationship[] @relation("fromPerson")

  toRelations Relationship[] @relation("toPerson")

  biography Biography?

  graveInfo GraveInfo?

  contributions EventContribution[]

  donations EventDonation[]

  createdAt DateTime @default(now())
}

model Biography {
  id        Int      @id @default(autoincrement())
  personId  Int      @unique
  content   String   @db.Text
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt
}

model GraveInfo {
  id        Int      @id @default(autoincrement())
  personId  Int      @unique
  cemetery  String?
  address   String?
  notes     String?  @db.Text
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt
}

model Relationship {
  id Int @id @default(autoincrement())

  fromId Int

  toId Int

  type RelationshipType

  from Person @relation("fromPerson", fields: [fromId], references: [id])

  to Person @relation("toPerson", fields: [toId], references: [id])

  createdAt DateTime @default(now())
}
