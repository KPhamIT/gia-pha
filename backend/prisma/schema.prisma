// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}



enum RelationshipType {
  FATHER
  MOTHER
  SPOUSE
  CHILD
}

model User {
  id          Int          @id @default(autoincrement())
  email       String?      @unique
  provider    String
  providerId  String       @unique

  person      Person?
  settings    UserSettings?

  createdAt   DateTime @default(now())
}

model UserSettings {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  data      Json     @default("{}")
  user      User     @relation(fields: [userId], references: [id])
  updatedAt DateTime @updatedAt
}

model Organization {
  id          Int      @id @default(autoincrement())
  name        String

  persons     Person[]

  createdAt   DateTime @default(now())
}

model Person {
  id              Int @id @default(autoincrement())

  organizationId  Int

  userId          Int? @unique

  fullName        String

  gender          String?

  birthDate       DateTime?

  deathDate       DateTime?

  avatar          String?

  generation      Int?

  branch          Int? @default(1)

  birthPlace      String?

  currentLocation String?

  education       String?

  occupation      String?

  religion        String?

  ethnicity       String?

  achievements    String? @db.Text

  organization    Organization @relation(fields: [organizationId], references: [id])

  user            User? @relation(fields: [userId], references: [id])

  fromRelations   Relationship[] @relation("fromPerson")

  toRelations     Relationship[] @relation("toPerson")

  biography       Biography?

  graveInfo       GraveInfo?

  createdAt       DateTime @default(now())
}

model Biography {
  id        Int      @id @default(autoincrement())
  personId  Int      @unique
  content   String   @db.Text
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt
}

model GraveInfo {
  id        Int      @id @default(autoincrement())
  personId  Int      @unique
  cemetery  String?
  address   String?
  notes     String?  @db.Text
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt
}

model Relationship {
  id        Int @id @default(autoincrement())

  fromId    Int

  toId      Int

  type      RelationshipType

  from      Person @relation("fromPerson", fields: [fromId], references: [id])

  to        Person @relation("toPerson", fields: [toId], references: [id])

  createdAt DateTime @default(now())
}
