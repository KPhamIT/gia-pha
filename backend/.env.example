DATABASE_URL=postgresql://user:password@localhost:5432/family_tree
# Max connections per app process (use 3–5 with PgBouncer/Neon session pooler)
DATABASE_POOL_MAX=5
JWT_SECRET=change-this-secret
PORT=5000
ALLOW_PUBLIC_ACCESS=true
# Default password for seeded admin user (username: admin)
ADMIN_PASSWORD=admin123
# Default password for seeded system user (username: system)
SYSTEM_PASSWORD=system123

# Zalo OAuth v4 (Social API) — https://developers.zalo.me/
ZALO_APP_ID=
ZALO_APP_SECRET=
ZALO_REDIRECT_URI=http://localhost:5000/auth/zalo/callback
FRONTEND_URL=http://localhost:3000

# OneSignal push notifications
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# Cron — GitHub Actions gọi POST /notifications/cron/death-anniversary (production)
# Cùng secret đặt trong GitHub repo Secrets → CRON_SECRET
CRON_SECRET=
# Chỉ bật @nestjs/schedule nội bộ khi dev local (production: false, xem docs/cron-github-actions.md)
ENABLE_INTERNAL_CRON=true

# Media upload driver: "local" | "cloudinary"
MEDIA_DRIVER=local
# Public backend base URL used for local file links (e.g. https://api.example.com)
MEDIA_BASE_URL=http://localhost:5000
# Optional alias for media base URL
PUBLIC_API_URL=http://localhost:5000

# Cloudinary (required when MEDIA_DRIVER=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend — email thông báo đăng ký dòng họ mới (xem docs/resend-setup.md)
RESEND_API_KEY=
# Địa chỉ gửi đã verify trên Resend, vd. Gia phả <noreply@mail.coinguon.io.vn>
RESEND_FROM_EMAIL=
# Tuỳ chọn: email nhận thông báo (mặc định: email tài khoản role SYSTEM)
ORG_REGISTRATION_NOTIFY_EMAIL=
